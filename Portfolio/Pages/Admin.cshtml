@page
@model AdminModel
@{
    ViewData["Title"] = "Admin Panel";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel - Portfolio</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body>
@if (!Model.IsLoggedIn)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height:100vh;background:#0d1117;">
        <div class="card shadow" style="width:360px;border:1px solid #30363d;border-radius:12px;background:#161b22;">
            <div class="card-body p-4">
                <h4 class="text-center mb-4" style="color:#f0f6fc;"><i class="fa-solid fa-lock me-2"></i>Admin Login</h4>
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
                }
                <form method="post" asp-page-handler="Login">
                    <div class="mb-3">
                        <label class="form-label" style="color:#8b949e;">User ID</label>
                        <input type="text" class="form-control" asp-for="UserId" required style="background:#0d1117;border-color:#30363d;color:#c9d1d9;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:#8b949e;">Password</label>
                        <input type="password" class="form-control" asp-for="Password" required style="background:#0d1117;border-color:#30363d;color:#c9d1d9;" />
                    </div>
                    <button type="submit" class="btn w-100" style="background:#238636;border-color:#2ea043;color:#fff;"><i class="fa-solid fa-right-to-bracket me-1"></i>Login</button>
                </form>
            </div>
        </div>
    </div>
}
else
{
    <!-- Top Bar -->
    <nav class="admin-topbar">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <span class="admin-brand"><i class="fa-solid fa-gear me-2"></i>Admin Panel</span>
            <div>
                <a href="/" class="btn btn-sm btn-outline-light me-2" target="_blank">
                    <i class="fa-solid fa-eye me-1"></i>View Site
                </a>
                <button class="btn btn-sm btn-success" id="btnSaveAll" onclick="saveAll()">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Save All
                </button>
                <form method="post" asp-page-handler="Logout" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger ms-2">
                        <i class="fa-solid fa-right-from-bracket me-1"></i>Logout
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <div class="admin-container">
        <!-- Sidebar Tabs -->
        <div class="admin-sidebar">
            <button class="tab-btn active" data-tab="profile"><i class="fa-solid fa-user me-2"></i>Profile</button>
            <button class="tab-btn" data-tab="education"><i class="fa-solid fa-graduation-cap me-2"></i>Education</button>
            <button class="tab-btn" data-tab="experience"><i class="fa-solid fa-briefcase me-2"></i>Experience</button>
            <button class="tab-btn" data-tab="skills"><i class="fa-solid fa-code me-2"></i>Skills</button>
            <button class="tab-btn" data-tab="projects"><i class="fa-solid fa-diagram-project me-2"></i>Projects</button>
            <button class="tab-btn" data-tab="contact"><i class="fa-solid fa-address-book me-2"></i>Contact</button>
        </div>

        <!-- Content -->
        <div class="admin-content">
            <!-- Toast -->
            <div class="toast-msg" id="toast"></div>

            <!-- Profile Tab -->
            <div class="tab-panel active" id="tab-profile">
                <h4>Profile</h4>
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" id="profileName" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" id="profileTitle" />
                </div>
                <div class="mb-3">
                    <label class="form-label">About Me</label>
                    <textarea class="form-control" id="profileAbout" rows="4"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Photo URL</label>
                    <input type="text" class="form-control" id="profilePhoto" />
                </div>
            </div>

            <!-- Education Tab -->
            <div class="tab-panel" id="tab-education">
                <h4>Education</h4>
                <div class="mb-3">
                    <label class="form-label">Degree</label>
                    <input type="text" class="form-control" id="eduDegree" />
                </div>
                <div class="mb-3">
                    <label class="form-label">College</label>
                    <input type="text" class="form-control" id="eduCollege" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Year</label>
                    <input type="text" class="form-control" id="eduYear" />
                </div>
            </div>

            <!-- Experience Tab -->
            <div class="tab-panel" id="tab-experience">
                <h4>Work Experience <button class="btn btn-sm btn-outline-primary ms-2" onclick="addExperience()"><i class="fa-solid fa-plus me-1"></i>Add Experience</button></h4>
                <div id="experienceContainer"></div>
            </div>

            <!-- Skills Tab -->
            <div class="tab-panel" id="tab-skills">
                <h4>Skills <button class="btn btn-sm btn-outline-primary ms-2" onclick="addSkillGroup()"><i class="fa-solid fa-plus me-1"></i>Add Group</button></h4>
                <div id="skillsContainer"></div>
            </div>

            <!-- Projects Tab -->
            <div class="tab-panel" id="tab-projects">
                <h4>Projects <button class="btn btn-sm btn-outline-primary ms-2" onclick="addProject()"><i class="fa-solid fa-plus me-1"></i>Add Project</button></h4>
                <div id="projectsContainer"></div>
            </div>

            <!-- Contact Tab -->
            <div class="tab-panel" id="tab-contact">
                <h4>Contact</h4>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" id="contactEmail" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" class="form-control" id="contactPhone" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Location</label>
                    <input type="text" class="form-control" id="contactLocation" />
                </div>
                <div class="mb-3">
                    <label class="form-label">LinkedIn URL</label>
                    <input type="url" class="form-control" id="contactLinkedIn" />
                </div>
                <div class="mb-3">
                    <label class="form-label">GitHub URL</label>
                    <input type="url" class="form-control" id="contactGitHub" />
                </div>
            </div>
        </div>
    </div>

}
    <script src="~/js/admin.js"></script>
</body>
</html>
